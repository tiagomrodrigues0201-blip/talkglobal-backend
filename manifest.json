{
  "manifest_version": 3,
  "name": "TalkGlobal",
  "short_name": "TalkGlobal",
  "version": "1.0.1",
  "description": "Responda mensagens em inglês no WhatsApp com 1 clique.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://talkglobal-backend.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "favicon-16x16.png",
    "32": "favicon-32x32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon128.png",
        "icon48.png",
        "favicon-16x16.png",
        "favicon-32x32.png"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "TalkGlobal"
  }
}
